rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - image: string (required)
    //   - category_en: string (required)
    //   - category_ka: string (required)
    //   - en: object (required)
    //   - ka: object (required)
    //   - order: number (optional)
    //   - created_at: timestamp (optional)
    //
    // Collection: faq
    // Document ID: faqId
    // Fields:
    //   - en: object (required)
    //   - ka: object (required)
    //   - order: number (optional)
    //   - created_at: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "verybadagency@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['image', 'category_en', 'category_ka', 'en', 'ka']) &&
             data.image is string && data.image.size() < 1000 &&
             data.category_en is string && data.category_en.size() < 100 &&
             data.category_ka is string && data.category_ka.size() < 100;
    }

    function isValidFaq(data) {
      return data.keys().hasAll(['en', 'ka']) &&
             data.en is map && data.ka is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /faq/{faqId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidFaq(request.resource.data);
      allow update: if isAdmin() && isValidFaq(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}

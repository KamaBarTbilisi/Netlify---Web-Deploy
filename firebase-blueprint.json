{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item with multilingual support and image.",
      "type": "object",
      "properties": {
        "image": { "type": "string", "description": "URL to the product image" },
        "category_en": { "type": "string", "description": "Category name in English" },
        "category_ka": { "type": "string", "description": "Category name in Georgian" },
        "order": { "type": "number", "description": "Display order" },
        "en": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "array", "items": { "type": "string" } },
            "nutrition": { "type": "string" },
            "category": { "type": "string" }
          }
        },
        "ka": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "array", "items": { "type": "string" } },
            "nutrition": { "type": "string" },
            "category": { "type": "string" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["image", "category_en", "category_ka", "en", "ka"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "A frequently asked question with multilingual support.",
      "type": "object",
      "properties": {
        "order": { "type": "number" },
        "en": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "answer": { "type": "string" }
          }
        },
        "ka": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "answer": { "type": "string" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["en", "ka"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of menu products"
    },
    "/faq/{faqId}": {
      "schema": "FAQ",
      "description": "Collection of FAQ items"
    }
  }
}
